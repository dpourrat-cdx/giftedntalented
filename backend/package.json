{
  "name": "giftedntalented-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "smoke:live": "tsx scripts/smoke-live-backend.ts",
    "start": "node dist/server.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "coverage:report": "tsx scripts/report-coverage.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.56.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.2",
    "firebase-admin": "^13.5.0",
    "helmet": "^8.1.0",
    "pino": "^10.0.0",
    "pino-http": "^11.0.0",
    "typescript": "^6.0.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.2",
    "jsdom": "^29.0.1",
    "pino-pretty": "^13.1.2",
    "supertest": "^7.0.0",
    "tsx": "^4.20.5",
    "vitest": "^4.1.2"
  }
}
